# Copy this file to ".env" (same folder) and fill in your values.
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows cmd)
#
# The .env file is gitignored, so your key never gets committed.
# These settings are only used for the OPTIONAL reasoning polish
# (rank.py --reasoning-llm) and the offline JD augmentation
# (precompute.py --augment-spec). The core ranking never needs them.
#
# Real environment variables still take precedence over this file.

# ---- Option A: Google Gemini (free tier, no local model) -------------------
LLM_PROVIDER=gemini
GEMINI_API_KEY=Your Api key
LLM_MODEL=gemini-2.5-flash

# ---- Option B: Ollama (fully local, no key) --------------------------------
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# OLLAMA_HOST=http://localhost:11434

# ---- Option C: Groq (free tier) --------------------------------------------
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...your_key_here
# LLM_MODEL=llama-3.1-8b-instant
